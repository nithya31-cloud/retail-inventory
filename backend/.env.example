# ── Server ────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (MySQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=retail_inventory_db

# ── JWT Auth ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── Python Analytics ─────────────────────────────
PYTHON_BIN=python3
ANALYTICS_SCRIPT=../python-analytics/analytics_engine.py
ANALYTICS_DATA_DIR=../python-analytics/data

# ── File Upload ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Currency ──────────────────────────────────────
CURRENCY=INR
CURRENCY_SYMBOL=₹
USD_TO_INR=83.5

# ── Frontend URL (CORS) ───────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
